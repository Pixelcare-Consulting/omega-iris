              <Text>{IIF(fn_get_wo_by_code.isAlternativeAddr,
    fn_get_wo_by_code.alternativeShippingAddr,
    fn_get_wo_shipping_addr_by_code.AddressName + "\n" +
    IIF(IsNullOrEmpty(fn_get_wo_shipping_addr_by_code.BuildingFloorRoom), "", fn_get_wo_shipping_addr_by_code.BuildingFloorRoom + " ") +
    IIF(IsNullOrEmpty(fn_get_wo_shipping_addr_by_code.Block), "", fn_get_wo_shipping_addr_by_code.Block + " ") +
    IIF(IsNullOrEmpty(fn_get_wo_shipping_addr_by_code.StreetNo), "", fn_get_wo_shipping_addr_by_code.StreetNo + " ") +
    IIF(IsNullOrEmpty(fn_get_wo_shipping_addr_by_code.Street), "", fn_get_wo_shipping_addr_by_code.Street) + "\n" +
    IIF(IsNullOrEmpty(fn_get_wo_shipping_addr_by_code.Address2), "", fn_get_wo_shipping_addr_by_code.Address2 + "\n") +
    IIF(IsNullOrEmpty(fn_get_wo_shipping_addr_by_code.Address3), "", fn_get_wo_shipping_addr_by_code.Address3 + "\n") +
    fn_get_wo_shipping_addr_by_code.City + ", " +
    fn_get_wo_shipping_addr_by_code.StateName + " " +
    fn_get_wo_shipping_addr_by_code.ZipCode + "\n" +
    IIF(IsNullOrEmpty(fn_get_wo_shipping_addr_by_code.County), "", fn_get_wo_shipping_addr_by_code.County + "\n") +
    fn_get_wo_shipping_addr_by_code.CountryName + "\n" +
    IIF(IsNullOrEmpty(fn_get_wo_shipping_addr_by_code.GlobalLocationNumber), "", fn_get_wo_shipping_addr_by_code.GlobalLocationNumber)
)}</Text>
